<?xml version="1.0" encoding="UTF-8"?>
<services>
    <service type="artery.application.CaService">
        <listener port="2001"/>
    </service>

    <service type="attacks.masquerade.Masquerade">
        <listener port="2002"/>
        <filters>
            <name pattern="cav-0"/>
        </filters>
    </service>

    <service type="cavise.application.CosimService">
        <listener port="2002"/>
        <filters>
            <!-- Inverse here means that matches are excluded - here we excluded attackers from victims -->
            <name pattern="cav-0" match="inverse"/>
            <name pattern="(cav|rsu)-.*"/>
        </filters>
    </service>
</services>
